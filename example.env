# Telegram bot
BOT_TOKEN=your_bot_token
# Telegram API proxy (set if api.telegram.org is blocked)
# TELEGRAM_API_ROOT=https://your-proxy-server.com/tg-proxy

# Redis — Telegraf sessions, payment_flags, moderation spam-cache (the bot's only store)
REDIS_URL=redis://localhost:6380

# auth-service (identity SoR: users, telegram linkage, telegram-auth confirm). Bot's service-token label = "bot".
AUTH_SERVICE_URL=http://localhost:8093
AUTH_SERVICE_TOKEN=dev-bot-token

# account-service (entitlement: API tokens, usage, tariff/subscription read-model). Bot's service-token label = "bot".
ACCOUNT_SERVICE_URL=http://localhost:8091
ACCOUNT_SERVICE_TOKEN=dev-bot-token

# billing-service (payments, subscriptions, tariff catalog)
BILLING_SERVICE_URL=http://localhost:8092
BILLING_SERVICE_TOKEN=dev-internal-token

# NATS — payment/subscription outcome events + tariff-catalog invalidation.
# Optional: if unset, the bot starts but emits no payment/subscription notifications.
NATS_URL=nats://localhost:4222

# Support group + operator chat (admin commands /pay, /confirm work only there)
CHAT_ID=
ADMIN_CHAT_ID=

# kinopoiskdev sync API for the admin update-movie / set-imdb scenes
UPDATE_API_BASE_URL=

# Optional health-check HTTP server (:3000)
ENABLE_HTTP_SERVER=false
# Skip the rebrand-blocker middleware (local/dev)
SKIP_REBRAND_BLOCKER=true
# Disable the daily chat-membership cron (e.g. on non-primary replicas)
# DISABLE_SCHEDULERS=true
